# Salesheet local dev mirror (Docker creates at build time)
website/salesheet/static/

# Fence calculator bundled into order_portal at build time by cloudbuild.yaml.
# Canonical source is scripts/fence-calculator/.
website/salesheet/order_portal/_fence_calc_bundled/

# docs/ staged into the salesheet Docker context by cloudbuild.yaml.
# Canonical source is docs/ at the repo root.
website/salesheet/_docs_staged/

# Claude Code local artifacts
.claude/pdf-pages/
.claude/render-test-*.png
.claude/swatch-chart.jpg

# WeChat-flooring ingestion working files (large source PDFs, text dumps, renders).
# Canonical PDFs live in gs://products-wood-assets/<vendor>/ and the source bucket
# gs://wechat-documents-attachments. The mapped JSON under data/incoming/parsed/
# and the handoff + export JSON ARE committed.
data/incoming/pdfs/

# Alma (almafloor.it) scrape — raw scrape is NOT committed:
#   - binary PDFs/images are mirrored to gs://products-wood-assets/alma/{docs,images}/
#     at ingest (system of record);
#   - the raw HTML pages embed Alma's own client-side Mapbox map token (Duda CMS),
#     which trips GitHub push-protection — so we keep them out of git entirely.
# The whole raw tree is reproducible via scripts/scrapers/alma_scrape.py. The
# durable, committed outputs are data/parsed/alma/*.json|csv and
# data/incoming/parsed/alma_*.json.
data/raw/alma/
