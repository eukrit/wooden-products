{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "wpc-fence-site",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", "./website", "-c-1"],
      "port": 8080,
      "autoPort": true
    },
    {
      "name": "wpc-profile-site",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8085", "--directory", "./website/salesheet"],
      "port": 8085,
      "autoPort": true
    },
    {
      "name": "wpc-deck-site",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8086", "--directory", "./website/salesheet"],
      "port": 8086,
      "autoPort": true
    },
    {
      "name": "panpruksa",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", "./website/panpruksa", "-p", "8090", "-c-1"],
      "port": 8090
    },
    {
      "name": "wpc-configurator",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", "./website/salesheet", "-p", "8091", "-c-1"],
      "port": 8091
    }
  ]
